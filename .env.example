# --- Local development defaults ---
# Local system Postgres (scripts/db-setup.sh creates this role + db)
DATABASE_URL=postgres://wedding:wedding@localhost:5432/wedding_game

# Signs the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=dev-only-secret-change-me

# Guards /admin. Generate with: openssl rand -hex 16
ADMIN_SECRET=dev-only-admin-secret

# console = print emails to the terminal (local dev)
# resend  = send via Resend (preview/prod; requires RESEND_API_KEY)
EMAIL_DRIVER=console
RESEND_API_KEY=
EMAIL_FROM="Combat IQ Game <game@example.com>"

# local       = store media in .uploads/ (local dev)
# vercel-blob = Vercel Blob (preview/prod; requires BLOB_READ_WRITE_TOKEN)
STORAGE_DRIVER=local
BLOB_READ_WRITE_TOKEN=
# Client mirror of STORAGE_DRIVER (the browser can only read NEXT_PUBLIC_*).
# MUST match STORAGE_DRIVER: set both to vercel-blob in production.
NEXT_PUBLIC_STORAGE_DRIVER=local

# Optional: enable the in-app MediaRecorder capture path (off until spiked on a real iPhone)
NEXT_PUBLIC_MEDIA_RECORDER=0
